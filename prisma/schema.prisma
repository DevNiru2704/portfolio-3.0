// Prisma schema - Postgres source of truth for portfolio content.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  category     String
  tags         String[]
  description  String
  overview     String?
  featured     Boolean  @default(false)
  github       String?
  live         String?
  // Shown in place of a link when there is not one: NDA-bound source, or a
  // launch still ahead. Keep them factual - they are read as commitments.
  sourceNote   String?
  liveNote     String?
  status       String   @default("draft")
  year         Int
  metrics      Json?
  features     String[]
  architecture String?
  challenges   String?
  tradeoffs    String?
  performance  String?
  // No accent column: the site has one accent (--signal in globals.css).
  cover        String?
  createdAt    DateTime @default(now())

  // Matches projectRepository.findAll (featured desc, year desc) and
  // findFeatured (where featured, year desc).
  @@index([featured, year])
}

model BlogPost {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  excerpt   String
  tags      String[]
  // No readTime column: it is derived from `body` in blogRepository, so it
  // cannot drift when the text changes.
  date      String
  status    String   @default("draft")
  body      String
  createdAt DateTime @default(now())

  // Matches blogRepository.findAll (date desc). date is an ISO YYYY-MM-DD
  // string, so lexicographic ordering equals chronological ordering.
  @@index([date])
}

model Lab {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  status      String
  tags        String[]
  progress    Int      @default(0)
  createdAt   DateTime @default(now())

  // Matches labRepository.findAll (createdAt asc).
  @@index([createdAt])
}

// Sections of the /now page. `goal` is expected to hold a single item.
enum NowCategory {
  building
  learning
  experimenting
  stack
  goal
}

model NowItem {
  id        String      @id @default(cuid())
  slug      String      @unique
  category  NowCategory
  body      String
  order     Int
  createdAt DateTime    @default(now())

  // Matches nowRepository.findAll (category, order asc).
  @@index([category, order])
}

model Principle {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  body      String
  order     Int
  createdAt DateTime @default(now())

  // Matches principleRepository.findAll (order asc).
  @@index([order])
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}
